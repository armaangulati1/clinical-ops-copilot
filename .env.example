# Anthropic API key for the agent orchestrator (Phase 1+)
ANTHROPIC_API_KEY=your-api-key-here

# Deployed clinical-data MCP (Phase 8; omit for local stdio)
CLINICAL_DATA_URL=https://clinical-data-mcp.fly.dev/mcp
CLINICAL_DATA_AUTH_TOKEN=your-clinical-data-bearer-token

# Prior-auth extractor backend: stub (offline regex) or real (agentic pipeline)
EXTRACTOR_BACKEND=stub

# ChartExtractor oncology API (optional override)
CHARTEXTRACT_API_URL=https://chartextract.onrender.com

# Agent orchestrator (Phase 4)
AGENT_RUNS_DIR=data/runs
ANTHROPIC_MODEL=claude-sonnet-4-5

CLINIC_OPS_LATENCY_MIN=0.5
CLINIC_OPS_LATENCY_MAX=3.0
CLINIC_OPS_FAILURE_RATE=0
# CLINIC_OPS_RNG_SEED=42
CLINIC_OPS_MOCK_TIMEOUT_SECONDS=30
CLINIC_OPS_MAX_ATTEMPTS=5

# Post-deploy smoke test (optional)
# CLINICAL_DATA_DEPLOY_URL=https://clinical-data-mcp.fly.dev
